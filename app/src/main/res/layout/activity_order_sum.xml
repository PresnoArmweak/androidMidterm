<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/orderSum"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:rowCount="5"
    android:columnCount="2"
    android:padding="24dp"
    android:useDefaultMargins="true"
    android:alignmentMode="alignBounds">

    <ImageView
        android:id="@+id/coffee"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_row="0"
        android:layout_column="0"
        android:layout_columnSpan="2"
        android:layout_marginBottom="32dp"
        android:contentDescription="@string/coffee_image"
        android:scaleType="centerInside"
        android:src="@drawable/coffeeimage" />

    <TextView
        android:id="@+id/nameLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_row="1"
        android:layout_column="0"
        android:paddingEnd="16dp"
        android:paddingStart="0dp"
        android:text="@string/name_on_order_label"
        android:textColor="@color/caramel_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/orderNameResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_row="1"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:textColor="?attr/colorSecondary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/typeLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_row="2"
        android:layout_column="0"
        android:paddingTop="8dp"
        android:text="@string/type_of_coffee_label"
        android:textColor="@color/caramel_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/coffeeTypeResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_row="2"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:paddingTop="8dp"
        android:textColor="?attr/colorSecondary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/shippingLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_row="3"
        android:layout_column="0"
        android:paddingTop="8dp"
        android:text="@string/shipping_label"
        android:textColor="@color/caramel_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/shippingResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_row="3"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:paddingTop="8dp"
        android:textColor="?attr/colorSecondary"
        android:textSize="18sp" />

    <TextView
        android:id="@+id/priceLable"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_row="4"
        android:layout_column="0"
        android:paddingTop="8dp"
        android:text="@string/price_label"
        android:textColor="@color/caramel_primary"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/priceResult"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_row="4"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:paddingTop="8dp"
        android:textColor="?attr/colorSecondary"
        android:textSize="18sp" />

</GridLayout>
