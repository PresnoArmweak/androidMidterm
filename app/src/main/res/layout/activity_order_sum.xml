<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/orderSum"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:rowCount="4"
    android:columnCount="4"
    android:padding="10dp"
    android:orientation="vertical"
    >

    <ImageView
        android:id="@+id/coffee"
        android:src="@drawable/coffeeimage"
        android:layout_height="150dp"
        android:layout_width="100dp"
        android:layout_column="0"
        android:layout_row="0"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:contentDescription="@string/coffee_image" />

   <TextView
        android:id="@+id/nameLable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="50dp"
        android:paddingBottom="10dp"
        android:layout_column="0"
        android:layout_row="1"
        android:text="@string/name_on_orderLable"
       />

    <TextView
        android:id="@+id/orderName"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_column="1"
        android:layout_row="1"/>


    <TextView
        android:id="@+id/typeLable"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_column="0"
        android:layout_row="2"
        android:text="@string/type_of_coffeeLable"
        />


    <TextView
        android:id="@+id/coffeeType"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_column="1"
        android:layout_row="2"
        android:text=""
        />

    <TextView
        android:id="@+id/shipping"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <TextView
        android:id="@+id/price"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

</GridLayout>
