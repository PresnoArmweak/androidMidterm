<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- caramel button -->
    <style name="Widget.Caramel.Button" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">#C8813A</item>
        <item name="android:textColor">#1A0F0A</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">16sp</item>
        <item name="cornerRadius">50dp</item>
        <item name="android:paddingStart">36dp</item>
        <item name="android:paddingEnd">36dp</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Underline input field -->
    <style name="Widget.Caramel.EditText" parent="Widget.AppCompat.EditText">
        <item name="android:textColor">#F5E6D3</item>
        <item name="android:textColorHint">#6B4C35</item>
        <item name="android:backgroundTint">#C8813A</item>
    </style>
</resources>